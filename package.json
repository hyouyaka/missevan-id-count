{
  "name": "missevan-counter",
  "version": "1.7.5",
  "description": "M&M Toolkit for Missevan and Manbo statistics.",
  "author": "M&M Toolkit",
  "type": "module",
  "main": "electron/main.mjs",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "vite build",
    "test:bundle": "node scripts/check-bundle-boundaries.mjs",
    "test:node": "node --test *.test.mjs shared/*.test.mjs server/*.test.mjs server/stats/*.test.mjs server/clients/*.test.mjs server/services/*.test.mjs src/app/*.test.mjs",
    "test:ui": "vitest run --config vitest.config.js",
    "test:e2e": "playwright test e2e/smoke.spec.mjs",
    "test:a11y": "playwright test e2e/a11y.spec.mjs",
    "typecheck": "tsc --noEmit --project jsconfig.check.json",
    "lint": "eslint . --max-warnings=0",
    "test": "npm run test:node && npm run test:ui",
    "start": "node server.js",
    "desktop": "npm run build && electron .",
    "pack:win": "npm run build && electron-builder --win portable --x64 --ia32"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "embla-carousel-react": "^8.6.0",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "lucide-react": "^0.542.0",
    "opencc-js": "^1.3.2",
    "pinyin-pro": "^3.28.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "twikoo": "^1.7.14",
    "undici": "^7.28.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@babel/core": "^7.29.1",
    "@xmldom/xmldom": "^0.8.13",
    "brace-expansion": "^2.0.3",
    "minimatch@^10.0.0": {
      "brace-expansion": "^5.0.7"
    },
    "fast-uri": "^3.1.3",
    "form-data": "^4.0.6",
    "hono": "^4.12.30",
    "lodash": "^4.18.1",
    "tar": "^7.5.16",
    "tmp": "^0.2.7"
  },
  "build": {
    "appId": "com.missevan.toolkit.desktop",
    "productName": "M&M Toolkit",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server.js",
      "server/**/*",
      "envConfig.js",
      "shared/**/*",
      "package.json"
    ],
    "win": {
      "icon": "windowsapp.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "artifactName": "M&M-Toolkit-${version}-${arch}.exe"
    }
  }
}
