{
  "name": "missevan-counter",
  "version": "1.7.2",
  "description": "M&M Toolkit for Missevan and Manbo statistics.",
  "author": "M&M Toolkit",
  "type": "module",
  "main": "electron/main.mjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "vite build",
    "test:bundle": "node scripts/check-bundle-boundaries.mjs",
    "test": "node --test *.test.mjs shared/*.test.mjs server/stats/*.test.mjs server/clients/*.test.mjs server/services/*.test.mjs src/app/*.test.mjs",
    "start": "node server.js",
    "desktop": "npm run build && electron .",
    "pack:win": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "embla-carousel-react": "^8.6.0",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "lucide-react": "^0.542.0",
    "node-fetch": "^3.3.2",
    "opencc-js": "^1.3.2",
    "pinyin-pro": "^3.28.1",
    "radix-ui": "^1.4.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "twikoo": "^1.7.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.12",
    "shadcn": "^4.2.0",
    "tailwindcss": "^4.1.13",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.missevan.toolkit.desktop",
    "productName": "M&M Toolkit",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server.js",
      "server/**/*",
      "envConfig.js",
      "shared/**/*",
      "package.json"
    ],
    "win": {
      "icon": "windowsapp.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "artifactName": "M&M-Toolkit-${version}-${arch}.exe"
    }
  }
}
